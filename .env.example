# Copy to .env for local development:
#   cp .env.example .env
#
# Local Postgres (Homebrew):
#   brew install postgresql@16
#   brew services start postgresql@16
#   createdb farm_logger
#
# Use your Mac username (no password for default local setup):
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/farm_logger

# Cloudflare R2 (optional locally; required on Render for persistent photos)
# R2_BUCKET_NAME=farm-logger-photos
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
